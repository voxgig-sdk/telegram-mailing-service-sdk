# Guide

guide: {
  metrics: count: entity: 1
  metrics: count: path: 2
  metrics: count: method: 4

  entity: mailing: {
    path: "/mailings": {
      op: create: method: *POST
      op: list: method: *GET
    }
    path: "/mailings/{mailingId}": {
      rename: param: "mailingId": *"id"
      op: load: method: *GET
      op: remove: method: *DELETE
    }
  }

}